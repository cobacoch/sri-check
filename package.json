{
  "name": "sri-check",
  "version": "1.0.0",
  "description": "GitHub Action to validate Subresource Integrity (SRI) attributes in HTML files",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --license licenses.txt",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint src",
    "lint:fix": "biome lint src --write",
    "format": "biome format src --write",
    "format:check": "biome format src",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cobacoch/script-integrity-checker-dev.git"
  },
  "keywords": [
    "github-action",
    "security",
    "sri",
    "subresource-integrity",
    "html",
    "integrity"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cobacoch/script-integrity-checker-dev/issues"
  },
  "homepage": "https://github.com/cobacoch/script-integrity-checker-dev#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^22.19.2",
    "@vercel/ncc": "^0.38.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@actions/core": "^2.0.1",
    "@actions/github": "^6.0.1",
    "cheerio": "^1.1.2",
    "minimatch": "^10.1.1"
  }
}
